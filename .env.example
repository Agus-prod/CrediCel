NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-local-anon-key

# URL pública o de la red local del panel. En un teléfono real no use localhost.
NEXT_PUBLIC_APP_URL=http://192.168.1.50:3001
NEXT_PUBLIC_CUSTOMER_PORTAL_URL=http://192.168.1.50:3002

# La app Expo solo debe recibir la clave pública anon; nunca service_role.
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=replace-with-public-anon-key
